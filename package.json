{
  "name": "syncup-app",
  "version": "0.3.0",
  "private": true,
  "description": "SyncUp desktop MVP built with Electron, React, Express, and MySQL",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\" \"npm run dev:electron\"",
    "dev:electron": "wait-on http://localhost:5173 http://localhost:4000 && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://localhost:5173 tsx electron/main.ts",
    "build": "npm run build --workspace backend && npm run build --workspace frontend && tsc -p electron/tsconfig.json",
    "package": "npm run build && electron-builder",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:migrate": "npm run prisma:migrate --workspace backend"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3"
  },
  "author": "SyncUp Team",
  "build": {
    "appId": "com.syncup.desktop",
    "productName": "SyncUp",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "frontend/dist/**/*",
      "backend/dist/**/*",
      "backend/package.json",
      {
        "from": "node_modules/.prisma",
        "to": "node_modules/.prisma",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/@prisma",
        "to": "node_modules/@prisma",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/.prisma/**/*",
      "node_modules/@prisma/**/*"
    ],
    "extraResources": [
      {
        "from": "database/prisma",
        "to": "database/prisma"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
